# =============================================================================
# env.swarmx.example — SwarmX V5.6-refined Environment Configuration
# Copy to .env.swarmx and source before running `ollama serve`:
#   cp env.swarmx.example .env.swarmx
#   source setup/ollama_env.sh
#
# CHANGES V5.6-refined:
#   ✦ SWARMX_OLLAMA_URL (primary) replaces SWARMX_OLLAMA_BASE_URL (deprecated).
#   ✦ SWARMX_FAST_MODEL added for tool_summarise_text configurability.
# =============================================================================

OLLAMA_FLASH_ATTENTION=1
OLLAMA_KV_CACHE_TYPE=q8_0
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_KEEP_ALIVE=300
OLLAMA_NUM_PARALLEL=1
OLLAMA_GPU_LAYERS=-1
OLLAMA_GPU_MEMORY_FRACTION=0.90

# V5.6-refined: Use SWARMX_OLLAMA_URL (matches orchestrator.py).
# SWARMX_OLLAMA_BASE_URL is deprecated — will emit a warning in health_check.
SWARMX_OLLAMA_URL=http://127.0.0.1:11434

# Fast model for tool_summarise_text (de-hardcoded in V5.6-refined).
SWARMX_FAST_MODEL=phi4-fast

SWARMX_AUTO_CRITIC=0
SWARMX_LOG_LEVEL=INFO
SWARMX_LOG_FORMAT=console

# MODELS_DIR=/media/nvme/models/llm-local
# SWARMX_DEBUG_RAW=0
# SWARMX_TRACE_DIR=traces