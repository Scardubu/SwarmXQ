# =============================================================================
# env.swarmx.example — SwarmX V6.2.16 Ollama & Video Runtime Environment
# Copy to .env.swarmx and source before running startup-enhanced.sh:
#   cp docs/env.swarmx.example .env.swarmx
#   source setup/ollama_env.sh  (or source scripts/startup-enhanced.sh)
#
# CHANGES V6.2.16:
#   ✦ SWARMX_VIDEO_JOB_LIMIT_PER_HOUR added (rate-limits job submissions).
#   ✦ SWARMX_VIDEO_EXPORT_TTL_DAYS added (controls export retention).
#   ✦ SWARMX_VIDEO_CLEANUP_INTERVAL_MS added (cleanup scan cadence).
#
# For the full API and dashboard env set, see env.example at repo root.
# This file covers Ollama tuning and the video-pipeline runtime flags.
# =============================================================================

# ── Ollama tuning ────────────────────────────────────────────────────────────
# startup-enhanced.sh overrides these automatically for the detected host
# profile (16gb or constrained). Manual values here override auto-detection.
# Q8 Phi-4 has shown CPU segfault risk with flash-attention/q8 KV on this host.
# Keep the local-first default conservative; GPU operators may override after validation.
OLLAMA_FLASH_ATTENTION=0
OLLAMA_KV_CACHE_TYPE=f16
SWARMX_HOST_PROFILE=auto
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_KEEP_ALIVE=0
OLLAMA_NUM_PARALLEL=1
OLLAMA_GPU_LAYERS=-1
OLLAMA_GPU_MEMORY_FRACTION=0.90

# Primary Ollama endpoint (replaces deprecated SWARMX_OLLAMA_BASE_URL).
SWARMX_OLLAMA_URL=http://127.0.0.1:11434

# Fast model for tool_summarise_text.
SWARMX_FAST_MODEL=instruct-phi4-pro-q8-prod

# Predictive prewarm — on by default on 16 GB host profile.
SWARMX_MODEL_STARTUP_PREWARM=1
SWARMX_MODEL_PREDICTIVE_PREWARM=1

SWARMX_AUTO_CRITIC=0
SWARMX_LOG_LEVEL=INFO
SWARMX_LOG_FORMAT=console

# ── Video pipeline runtime flags ─────────────────────────────────────────────
# LOW_RAM_MODE is auto-enabled when MemAvailable < 6170 MB (shouldAutoEnableLowRamMode).
# Set to 1 to force-enable; set to 0 to force-disable auto-detection.
SWARMX_VIDEO_LOW_RAM_MODE=0

# Dev/test only. Never enable in production — narrated output is suppressed.
SWARMX_VIDEO_ALLOW_SILENT_AUDIO=0

# ── Video rate limiting & cleanup (V6.2.16) ───────────────────────────────────
# Max video job submissions per connection per hour (sliding window).
# Exceeding this returns 429 {error:"rate_limited"}. Default: 10.
SWARMX_VIDEO_JOB_LIMIT_PER_HOUR=10

# Caption scoring rate limit (requests/minute/connection). Default: 10.
SWARMX_VIDEO_CAPTION_SCORE_LIMIT_PER_MIN=10

# Days after which rendered exports and artifacts are eligible for cleanup.
# Cleanup service first runs 30 s after API boot, then every INTERVAL_MS.
SWARMX_VIDEO_EXPORT_TTL_DAYS=7
SWARMX_VIDEO_CLEANUP_INTERVAL_MS=21600000
