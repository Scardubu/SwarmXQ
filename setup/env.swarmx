# =============================================================================
# env.swarmx  —  SwarmX V5.7 Ollama Environment Configuration
# =============================================================================
# USAGE:
#   source setup/env.swarmx        # loads into current shell
#   ollama serve &                 # Ollama reads vars at serve time
#
# Ollama reads these at SERVE TIME — not at `ollama create` time.
# Changes require restarting the Ollama server to take effect.
#
# HARDWARE TARGET: 8 GB RAM + 12 GB VRAM
#
# CHANGES V5.7:
#   ✦ TOOL_CB_THRESHOLD, TOOL_CB_RESET_S added  [V5.7-ENH-02 circuit breaker]
#   ✦ SWARMX_DISPATCH_LOG added (mirrors observability.dispatch_log in config)
#   ✦ SWARM_ROOT, SWARM_HOME added (skill loader + evolution layer path roots)
#   ✦ TOOL_RATE_LIMIT_PER_MIN documented (was read but undocumented)
# =============================================================================

# ── Core inference performance ────────────────────────────────────────────────
export OLLAMA_FLASH_ATTENTION=1
export OLLAMA_KV_CACHE_TYPE=q8_0
export OLLAMA_NUM_PARALLEL=1
export OLLAMA_MAX_LOADED_MODELS=1
export OLLAMA_KEEP_ALIVE=300
export OLLAMA_GPU_LAYERS=-1
export OLLAMA_GPU_MEMORY_FRACTION=0.90

# ── Networking ────────────────────────────────────────────────────────────────
export OLLAMA_HOST=http://localhost:11434

# ── Logging ───────────────────────────────────────────────────────────────────
export OLLAMA_LOG_LEVEL=info

# ── SwarmX orchestrator settings ──────────────────────────────────────────────

# PRIMARY Ollama URL — read by orchestrator.OLLAMA_BASE_URL() and health_check.py
export SWARMX_OLLAMA_URL="http://localhost:11434"

# Deprecated alias — kept for backwards compat. Emits warning in health_check.
# Remove after all scripts are updated.
export SWARMX_OLLAMA_BASE_URL="http://localhost:11434"

# Fast model tag — read by tool_summarise_text (de-hardcoded in V5.6)
export SWARMX_FAST_MODEL="phi4-fast"

# Request timeout in seconds (overrides swarmx_config.yaml if set)
export SWARMX_REQUEST_TIMEOUT=180

# Max retries per step (overrides swarmx_config.yaml if set)
export SWARMX_MAX_RETRIES=3

# Set to 1 to run critic automatically after every task
export SWARMX_AUTO_CRITIC=0

# [V5.7] Tool dispatch log path — consumed by orchestrator [ENH-01] and health_check μ-6
# Must match observability.dispatch_log in swarmx_config.yaml.
export SWARMX_DISPATCH_LOG="dispatch.jsonl"

# [V5.7] SWARM_ROOT — skill library root path consumed by _load_skill_fragment()
# Set to the absolute path of the SwarmX-1.2 checkout.
export SWARM_ROOT="${HOME}/.swarmx"

# [V5.7] SWARM_HOME — evolution layer root (evolution-layer/latest.json persisted here)
export SWARM_HOME="${HOME}/.swarmx"

# ── Tool rate limiting ────────────────────────────────────────────────────────
# Global fallback rate limit (calls/min) applied when no per-tool limit is set.
# Per-tool limits from swarmx_config.yaml tool_rate_limits section override this.
export TOOL_RATE_LIMIT_PER_MIN=60

# ── Circuit breaker ───────────────────────────────────────────────────────────
# [V5.7-ENH-02] After TOOL_CB_THRESHOLD consecutive failures the circuit opens.
# After TOOL_CB_RESET_S seconds, a single half-open probe is allowed.
# These env vars take precedence over circuit_breaker section in config.
export TOOL_CB_THRESHOLD=5
export TOOL_CB_RESET_S=60.0

# ── structlog settings ────────────────────────────────────────────────────────
export SWARMX_LOG_LEVEL=INFO
export SWARMX_LOG_FORMAT=console

# ── Gate configuration ────────────────────────────────────────────────────────
# export SWARM_GATE_STRICT=1
# export SWARM_GATE_FAIL_ON_WARN=1

# ── Development overrides ─────────────────────────────────────────────────────
# export MODELS_DIR=/media/nvme/models/llm-local
# export SWARMX_DEBUG_RAW=0

# ── Evolution pass overrides ──────────────────────────────────────────────────
# export OLLAMA_MAX_LOADED_MODELS=1
# export OLLAMA_KEEP_ALIVE=600

# ── LLM response cache (eval/bench only — disable in production) ──────────────
# export SWARM_LLM_CACHE_DIR="${HOME}/.swarmx/llm-cache"

# ── Verification ─────────────────────────────────────────────────────────────
echo "[SwarmX env V5.7] Loaded."
echo "  Ollama host      : ${OLLAMA_HOST}"
echo "  SWARMX_OLLAMA_URL: ${SWARMX_OLLAMA_URL}"
echo "  Flash-Attn       : ${OLLAMA_FLASH_ATTENTION}    KV cache: ${OLLAMA_KV_CACHE_TYPE}"
echo "  Max loaded       : ${OLLAMA_MAX_LOADED_MODELS}   Keep-alive: ${OLLAMA_KEEP_ALIVE}s"
echo "  Auto-critic      : ${SWARMX_AUTO_CRITIC}    Log level: ${SWARMX_LOG_LEVEL}"
echo "  CB threshold     : ${TOOL_CB_THRESHOLD} failures / reset: ${TOOL_CB_RESET_S}s"
echo "  Dispatch log     : ${SWARMX_DISPATCH_LOG}"