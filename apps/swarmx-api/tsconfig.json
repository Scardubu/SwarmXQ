{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "outDir": "dist",
    "rootDir": "../..",
    "baseUrl": ".",
    "paths": {
      "@swarmx/types": ["../../packages/swarmx-types/src/index.ts"],
      "@swarmx/types/operator-map": ["../../packages/swarmx-types/src/operator-map.ts"],
      "@swarmx/types/operation-types": ["../../packages/swarmx-types/src/operation-types.ts"]
    },
    "strict": true,
    "noImplicitAny": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "src/**/*",
    "../../packages/swarmx-types/src/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
