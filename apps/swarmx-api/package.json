{
  "name": "@swarmx/api",
  "version": "2026.6.0",
  "private": true,
  "type": "module",
  "main": "dist/apps/swarmx-api/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/apps/swarmx-api/src/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:video": "node --import tsx scripts/video-regression-check.ts",
    "test:video:smoke": "node --import tsx scripts/video-render-smoke.ts",
    "test:series": "node --import tsx scripts/series-regression.ts",
    "test:models": "node --import tsx scripts/model-registry-modelfile-check.ts",
    "test:factory": "node --import tsx scripts/creative-factory-release-check.ts",
    "test:regression": "node --import tsx scripts/eviction-metric-regression.ts && node --import tsx scripts/system-health-regression.ts && node --import tsx scripts/reasoning-sanitizer-regression.ts && node --import tsx scripts/adaptive-timeout-regression.ts && node --import tsx scripts/model-registry-modelfile-check.ts && node --import tsx scripts/series-regression.ts && node --import tsx scripts/creative-factory-release-check.ts",
    "test:m13": "node --import tsx scripts/m13-live-cert.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/websocket": "^11.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-trace-node": "^2.9.0",
    "@swarmx/types": "workspace:*",
    "bullmq": "^5.31.0",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.1",
    "node-pty": "^1.0.0",
    "systeminformation": "^5.23.10",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.9",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
