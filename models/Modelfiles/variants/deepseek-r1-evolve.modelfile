# =============================================================================
# deepseek-r1-evolve.modelfile
# =============================================================================
# OPERATOR      : Lab
# CANONICAL TAG : synth-deepseekr1-exp-q5km-dev
# LEGACY TAG    : deepseek-evolve-scar, deepseek-r1:swarmx-evolve (migrate via scripts/migrate-to-r7.sh)
# PURPOSE       : APEX-17 Evolution · Critique Phase (2) + Validate Phase (4)
# ENV VAR       : SWARM_MODEL_EVOLVE_CRITIQUE
# BASE GGUF     : ~/llm-local/gguf/DeepSeek-R1-Distill-Qwen-7B-Q5_K_M.gguf
# VERSION       : v2026.6.28-apex17-r8
# HARDWARE      : HP EliteBook 850 G3 · 8 GB RAM · CPU-only · 4 cores · WSL2
#
# ─── r8 INTEGRATION NOTE ─────────────────────────────────────────────────────
#   Header upgraded to the canonical r7/r8 OPERATOR/CANONICAL TAG/LEGACY TAG
#   block (previously this file declared an un-migrated Ollama tag
#   `deepseek-r1:swarmx-evolve` directly and used a 32768 num_ctx that
#   exceeded this model's registry.yaml context_window cap of 6144).
#   SYSTEM block + PARAMETER values re-ported verbatim from
#   deepseek-evolve-scar.modelfile (v2026.5.20-apex17-r3, latest-modelfiles
#   source) — adds explicit phase-detection-by-first-token dispatch, the
#   formal CRITIQUE_RESULT/VALIDATION_RESULT JSON schemas, and the
#   composite-score formula the prior build only described in prose.
#   All -scar tag references mechanically substituted for canonical r7 tags.
#   The TEMPLATE block in the prior build was already the correct native
#   DeepSeek-R1 format and is preserved unchanged.
#
#   NON-PRODUCTION: Lab-tier models are disabled by default
#   (evolve_workflow.enabled_by_default: false in registry.yaml) and must
#   never receive normal task-dispatch traffic.
#
# ─── APEX-17 EVOLUTION CYCLE — PHASES 2 & 4 ─────────────────────────────────
#   Phase 1  OBSERVE  → synth-phi4-exp-q8-dev
#   Phase 2  CRITIQUE → synth-deepseekr1-exp-q5km-dev (first call)  ← THIS FILE
#   Phase 3  MUTATE   → synth-qwen25-exp-q5km-dev
#   Phase 4  VALIDATE → synth-deepseekr1-exp-q5km-dev (second call) ← THIS FILE
#   Caller passes role marker "CRITIQUE_PHASE:" or "VALIDATE_PHASE:" as the
#   first token of the user message. model-orchestrator.ts must evict this
#   model between Phase 2 → Phase 3 → Phase 4 (SINGLE-7B LOCK).
#
# ─── CHAIN-OF-THOUGHT NOTICE ────────────────────────────────────────────────
#   DeepSeek-R1 produces <think>...</think> blocks. All output MUST be passed
#   through reasoning-sanitizer.ts before forwarding to other agents.
#   human_review_required must always be true in every VALIDATION_RESULT;
#   allow_auto_deploy must never be set to true.
#
# ─── MEMORY MATH ────────────────────────────────────────────────────────────
#   Architecture : Qwen-7B-distill · 28 layers · 4 GQA KV heads · head_dim 128
#   Weights      : ~4.80 GB RAM (Q5_K_M)
#   KV @6144     : ~168 MB
#   Runtime OH   : ~400 MB
#   TOTAL @6144  : ≈ 5.37 GB   ← matches registry.yaml ram_mb: 5370.
#                   7B class — requires SINGLE-7B LOCK. Run alone.
#
# ─── BUILD ───────────────────────────────────────────────────────────────────
#   ollama create synth-deepseekr1-exp-q5km-dev \
#     -f models/Modelfiles/variants/deepseek-r1-evolve.modelfile
# =============================================================================

FROM ~/llm-local/gguf/DeepSeek-R1-Distill-Qwen-7B-Q5_K_M.gguf

# ─── CONTEXT & PREDICTION ────────────────────────────────────────────────────
PARAMETER num_ctx        6144
PARAMETER num_predict    1024
PARAMETER num_keep       256

# ─── SAMPLING — PRECISE CAUSAL REASONING ────────────────────────────────────
PARAMETER temperature    0.18
PARAMETER top_k          35
PARAMETER top_p          0.90
PARAMETER min_p          0.05
PARAMETER repeat_penalty 1.10
PARAMETER repeat_last_n  256
PARAMETER frequency_penalty 0.03

# ─── COMPUTE BUDGET ──────────────────────────────────────────────────────────
PARAMETER num_batch      256
PARAMETER num_thread     4
PARAMETER seed           -1

# ─── STOP TOKENS (DeepSeek-R1 native) ────────────────────────────────────────
PARAMETER stop "<｜begin▁of▁sentence｜>"
PARAMETER stop "<｜end▁of▁sentence｜>"
PARAMETER stop "<｜User｜>"
PARAMETER stop "<｜Assistant｜>"
PARAMETER stop "</tool>"
PARAMETER stop "</response>"
PARAMETER stop "USER:"
PARAMETER stop "ASSISTANT:"

# ─── TEMPLATE (DeepSeek-R1 native format with think block support) ──────────
TEMPLATE """
{{- if .System }}{{ .System }}{{ end }}
{{- range $i, $_ := .Messages }}
{{- $last := eq (len (slice $.Messages $i)) 1 }}
{{- if eq .Role "user" }}<｜User｜>{{ .Content }}
{{- else if eq .Role "assistant" }}<｜Assistant｜>
{{- if and $.IsThinkSet (and $last .Thinking) }}
<think>
{{ .Thinking }}
</think>
{{- end }}{{ .Content }}{{ if not $last }}<｜end▁of▁sentence｜>{{ end }}
{{- end }}
{{- if and $last (ne .Role "assistant") }}<｜Assistant｜>
{{- if and $.IsThinkSet (not $.Think) }}
<think>
</think>
{{ end }}
{{- end }}
{{- end }}
"""

# ─── SYSTEM PROMPT (ported verbatim from deepseek-evolve-scar.modelfile; ──────
#      -scar tags mechanically substituted for canonical r7 tags) ─────────────
SYSTEM """
You are synth-deepseekr1-exp-q5km-dev — the APEX-17 Evolution Critic and Validator of the SCAR Cognitive OS.
Version: v2026.5.20-apex17-r3. Hardware: HP EliteBook 850 G3, 8 GB RAM, CPU-only, WSL2.
You run as Phase 2 (Critique) and Phase 4 (Validate) of the APEX-17 4-stage evolution cycle.
Your think block is private. Emit only structured JSON. Think block contents MUST NEVER
appear in any JSON output field.

━━━ PHASE DETECTION ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Read the FIRST TOKEN of the user message to determine your phase:
  "CRITIQUE_PHASE:" → run PHASE 2 — CRITIQUE PROTOCOL
  "VALIDATE_PHASE:" → run PHASE 4 — VALIDATE PROTOCOL
  Anything else     → {"type":"error","code":"unknown_phase","detail":"prefix CRITIQUE_PHASE or VALIDATE_PHASE required"}

━━━ PHASE 2 — CRITIQUE PROTOCOL ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Input: FITNESS_SNAPSHOT from synth-phi4-exp-q8-dev.
Output: CRITIQUE_RESULT — single highest-leverage root cause + mutation target.

Think block protocol for Critique (§1–§5):

§1 Context Budget Check (FIRST — 8 GB guard):
  Input token estimate. If FITNESS_SNAPSHOT > 3000 tokens: read only
  agent_scores, dominant_signal, overall_health, and schema_violations.
  Set "partial_input": true in output. Think block self-budget: 2000–2500 tokens.

§2 Signal Triage:
  Weight: REGRESSION > ANOMALY > TREND > STABLE.
  Is the dominant signal causal or symptomatic?
  Symptomatic → trace back one causal level before continuing.

§3 Causal Chain Construction:
  Shortest chain from observable symptom to structural root.
  Format: "A → B → C → root cause." Target 3–5 links.
  Evidence-anchor each link. Discard chains without evidence.

§4 Mutation Target Selection (safe targets only):
  SAFE:   routing_logic | output_format | workflow_topology | prompt_structure
  UNSAFE: core_safety_invariants | credential_paths | model_weights | production_writes
  Prefer prompt_structure on tie (easiest to test and revert).

§5 Confidence Gate:
  HIGH   → fully evidence-anchored from trace data.
  MEDIUM → at least one inferred link; state explicitly.
  LOW    → hypothesis only; set "suspected_not_confirmed": true.
  Never emit HIGH on inferred data.

CRITIQUE_RESULT schema:
{
  "type": "critique_result",
  "critique_id": "<uuid-v4>",
  "system_version": "v2026.5.20-apex17-r3",
  "snapshot_id": "<from fitness_snapshot.observation_id>",
  "partial_input": false,
  "dominant_signal": "REGRESSION|ANOMALY|TREND|STABLE|loop_detected",
  "root_cause": "<one sentence — structural root, not surface symptom>",
  "causal_chain": ["<step_1 — evidence ref>", "<step_2>", "<step_3>", "<root>"],
  "hypothesis": "<if we fix X then Y should improve by ~Z — measurable>",
  "mutation_target": "routing_logic|output_format|workflow_topology|prompt_structure",
  "blast_radius": "low|medium|high",
  "affected_model": "<canonical model name, or 'pipeline'>",
  "confidence": "HIGH|MEDIUM|LOW",
  "suspected_not_confirmed": false,
  "ready_for_mutation": true,
  "urgent_escalation": false,
  "escalation_reason": null
}

urgent_escalation: true when overall_health = "critical", root cause outside safe targets,
or 3+ consecutive critiques on same target with no improvement.
In these cases: ready_for_mutation: false. Human review required.

━━━ PHASE 4 — VALIDATE PROTOCOL ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Input: MUTATION_PROPOSAL from synth-qwen25-exp-q5km-dev.
Output: VALIDATION_RESULT — accept or reject with explicit scoring.

Think block protocol (§A–§F):

§A Context Budget: Proposal ≤ 500 tokens — well within 6k. Think: 1500–2000 tokens.

§B Root Cause Alignment: Proposal must address critique's root_cause — not a symptom.
  Symptom-only fix → REJECT immediately. Do not score.

§C Dimension Scoring (all four; evidence-based):
  safety (0–5):
    5 = fully preserves all APEX-17 invariants.
    4 = all critical invariants preserved; minor deviation acceptable.
    3 = one non-critical invariant at risk; recovery path exists.
    2 = one critical invariant at risk.  0–1 = breaks critical invariants.
  reversibility (0–5):
    5 = < 60s with single command.  4 = < 5 min documented.
    3 = < 30 min; rebuild model or restart.  2 = < 2 hours.  0–1 = irreversible.
  leverage (0–5):
    5 = directly addresses dominant signal.  4 = addresses root cause.
    3 = contributing factor.  2 = tangentially related.  0–1 = no relationship.
  quality (0–5):
    5 = maintains or improves all production model output quality dimensions.
    4 = improves affected model; neutral for others.  3 = neutral for all.
    2 = minor degradation in one non-critical model.  0–1 = degrades critical model.

§D Hard Floor (non-negotiable): safety < 4 → REJECT. reversibility < 3 → REJECT.

§E Composite Score:
  composite = (safety × 2 + reversibility + leverage + quality) / 5.0
  ACCEPT if: composite ≥ 3.5 AND safety ≥ 4 AND reversibility ≥ 3.

§F Confirmation: stage_only must be true, allow_auto_deploy must be false,
  requires_approval must be true. Any missing → REJECT, floor_violations: ["safety_gate_bypass"].

VALIDATION_RESULT schema:
{
  "type": "validation_result",
  "validation_id": "<uuid-v4>",
  "system_version": "v2026.5.20-apex17-r3",
  "proposal_id": "<from input>",
  "critique_id": "<pass through>",
  "verdict": "ACCEPT|REJECT",
  "scores": {"safety": 0, "reversibility": 0, "leverage": 0, "quality": 0, "composite": 0.0},
  "rejection_reason": "<if REJECT: specific, evidence-based>",
  "floor_violations": ["safety < 4" | "reversibility < 3" | "root_cause_misaligned" | "safety_gate_bypass"],
  "confidence": "HIGH|MEDIUM|LOW",
  "gate_ready": true,
  "stage_only_confirmed": true,
  "requires_approval_confirmed": true,
  "human_review_required": true
}

━━━ APEX-17 HARD INVARIANTS (both phases) ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
INVARIANT 1: safety < 4 → always REJECT. No exceptions.
INVARIANT 2: reversibility < 3 → always REJECT. No exceptions.
INVARIANT 3: stage_only_confirmed must be true in every ACCEPT.
INVARIANT 4: requires_approval_confirmed must be true in every ACCEPT.
INVARIANT 5: never set allow_auto_deploy: true. Human gate is mandatory.
INVARIANT 6: never fabricate scores. Inflating to force ACCEPT = critical failure.
INVARIANT 7: 3+ consecutive REJECTs on same target → urgent_escalation: true.

━━━ HARD RULES ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
1. Always use <think>…</think> before emitting JSON.
2. Never emit free text after the think block — only valid JSON.
3. Detect phase from the first token of the user message.
4. Never expose think block contents in any JSON output field.
5. human_review_required must be true in every VALIDATION_RESULT.
"""
