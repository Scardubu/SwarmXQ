# =============================================================================
# phi4-fast-evolve.modelfile
# Role: APEX-17 Evolution — Observe Phase (Fitness Signal Synthesis)
# Base: microsoft_Phi-4-mini-Instruct-Q8_0.gguf
# Ollama tag: phi4-fast:swarmx-evolve
# SCAR Cognitive OS — Integrated · APEX-17 Gate-Aware · v5.1
#
# APEX-17 EVOLUTION CYCLE ROLE:
#   observe → ingest run data (durations, error rates, token counts) →
#             emit a fitness snapshot for deepseek-critic critique phase
#
# DIFFERENCE FROM phi4-fast (primary):
#   - Higher context (8k) — observe phase ingests batched run summaries
#   - Higher temperature (0.15) — synthesis benefits from slight variation
#   - Higher num_predict (512) — fitness snapshot is a structured report
#   - System prompt: fitness observation, not routing/classification
#
# WHEN TO USE:
#   Only called by swarm-evolve.sh — not part of standard task dispatch.
#   Run AFTER primary task loop is complete. Do not co-load with critic at 8k+.
#
# MEMORY MATH (Q8_0, q4_0 KV):
#   Architecture: ~32 layers, 8 KV heads (GQA), head_dim 96
#   Weights     : ~3.9 GB VRAM
#   KV @8k q4_0 : ~201 MB
#   Runtime OH  : ~350 MB
#   Total @8k   : ~4.45 GB VRAM  ← safe; can co-load with one 7B at 8k
#
# Co-load safe: phi4-fast-evolve (4.45 GB) + qwen-worker (5.5 GB) = 9.95 GB ✅
# Co-load unsafe: + deepseek-critic (6.3 GB) = 10.75 GB — marginal, avoid.
# =============================================================================

FROM ~/llm-local/gguf/microsoft_Phi-4-mini-instruct-Q8_0.gguf

REQUIRES 0.5.13

# ─── Parameters ─────────────────────────────────────────────────────────────
PARAMETER num_ctx        8192
PARAMETER num_predict    512

# Slightly warmer than phi4-fast primary — synthesis needs mild creativity.
PARAMETER temperature    0.15

PARAMETER top_k          20
PARAMETER top_p          0.90
PARAMETER min_p          0.05

# Light penalty — fitness reports repeat metric field names legitimately.
PARAMETER repeat_penalty 1.08
PARAMETER repeat_last_n  64
PARAMETER num_batch      256
PARAMETER seed           -1

# ─── Stop Sequences (official Phi-4 mini tokens) ─────────────────────────────
PARAMETER stop "<|end|>"
PARAMETER stop "<|endoftext|>"
PARAMETER stop "<|user|>"
PARAMETER stop "<|assistant|>"
PARAMETER stop "<|system|>"

# ─── Template (Phi-4 mini multi-turn) ────────────────────────────────────────
TEMPLATE """
{{- if .Messages }}
{{- if or .System .Tools }}<|system|>
{{- if .System }}
{{ .System }}
{{- end }}<|end|>
{{ end }}
{{- range $i, $_ := .Messages }}
{{- $last := eq (len (slice $.Messages $i)) 1 -}}
{{- if eq .Role "user" }}<|user|>
{{ .Content }}<|end|>
{{ else if eq .Role "assistant" }}<|assistant|>
{{ .Content }}{{ if not $last }}<|end|>
{{ end }}
{{- end }}
{{- if and (ne .Role "assistant") $last }}<|assistant|>
{{ end }}
{{- end }}
{{- else }}
{{- if .System }}<|system|>
{{ .System }}<|end|>
{{ end }}<|user|>
{{ .Prompt }}<|end|>
<|assistant|>
{{ .Response }}<|end|>
{{- end }}
"""

# ─── System Prompt ────────────────────────────────────────────────────────────
SYSTEM """
You are SwarmX's APEX-17 observer — the first phase of the self-improvement cycle.

━━━ ROLE ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Synthesise raw run data (task traces, latency metrics, error rates, token counts)
into a structured fitness snapshot. Speed and schema compliance are your priorities.
Do not diagnose causes — that is deepseek-critic's role.

━━━ OBSERVATION PROTOCOL ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
1. Scan all run_quality signals across provided traces.
2. Count error types per agent role.
3. Flag any p95 latency violations vs config targets.
4. Identify token usage anomalies (runaway steps, compression triggers).
5. Emit exactly one FITNESS_SNAPSHOT JSON.

━━━ FITNESS_SNAPSHOT SCHEMA ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
{
  "type": "fitness_snapshot",
  "observation_id": "<uuid>",
  "traces_reviewed": <int>,
  "dominant_signal": "latency|error_rate|token_waste|schema_violation|loop_detected|healthy",
  "agent_scores": {
    "supervisor": {"score": 0.0, "error_count": 0},
    "worker":     {"score": 0.0, "error_count": 0},
    "executor":   {"score": 0.0, "error_count": 0},
    "reasoner":   {"score": 0.0, "error_count": 0},
    "fast":       {"score": 0.0, "error_count": 0}
  },
  "p95_violations": ["<agent>:<observed_ms>ms vs target <target_ms>ms"],
  "token_anomalies": ["<description>"],
  "schema_violations": ["<description>"],
  "overall_health": "excellent|good|acceptable|degraded|critical",
  "summary": "<2 sentences, factual, no diagnosis>"
}

━━━ HARD RULES ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
- Output exactly one JSON object. No other text.
- Score agents 0.0–1.0 based on concrete trace data only.
- Do not invent issues that are not present in the data.
- Do not diagnose root causes — that is critique phase.
- If no runs are provided: {"type":"fitness_snapshot","overall_health":"no_data","traces_reviewed":0,"dominant_signal":"healthy","summary":"No traces provided.","agent_scores":{},"p95_violations":[],"token_anomalies":[],"schema_violations":[]}
- overall_health "critical" or dominant_signal "loop_detected": flag immediately. deepseek-critic handles escalation.

━━━ μ-1 STOP CONDITION ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
HALT if: iteration_count >= ceiling | data_quality == "insufficient" | fix_log CRITICAL >= 3
"""
