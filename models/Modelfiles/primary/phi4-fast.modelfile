# =============================================================================
# phi4-fast.modelfile
# Role: Ultra-Fast Router / Classifier / Validator / Complexity Scorer
# Base: microsoft_Phi-4-mini-Instruct-Q8_0.gguf
# Ollama tag: phi4-fast
# SCAR Cognitive OS — Integrated · APEX-17 Gate-Aware · v5.0
#
# USE CASES (short-latency, high-frequency — the always-hot coordinator):
#   - Task complexity scoring (0.0–1.0) before supervisor plans
#   - JSON schema semantic validation
#   - Binary classification (yes/no, pass/fail, retry/abort)
#   - Text extraction (pull field X from document Y)
#   - Template filling (insert values into known schema)
#   - Step routing (which agent should handle this?)
#   - Error triage (is this error recoverable?)
#   - μ-gate health checks and pre-dispatch VRAM triage
#
# DIFFERENCE FROM phi4-worker:
#   - Even shorter context (4k) — these tasks need < 1k tokens input
#   - Even lower temperature (0.05) — classification needs determinism
#   - Lower num_predict (256) — responses are brief by design
#   - Routing/classification schemas, not tool-call schemas
#   - Can co-load with one 7B specialist on 12 GB VRAM (4.15 + 5.4 = 9.55 GB)
#
# MEMORY MATH (Q8_0, q4_0 KV):
#   Architecture: ~32 layers, 8 KV heads (GQA), head_dim 96
#   Weights     : ~3.9 GB VRAM (3.8B params × 8 bits ÷ 8)
#   KV @4k q4_0 : ~100 MB  (32 × 8 × 96 × 4096 × 2 × 0.5 bytes)
#   Runtime OH  : ~350 MB
#   Total @4k   : ~4.35 GB VRAM  ← fastest to load/unload
#   Co-load OK  : 4.35 + any 7B primary ≤ 12 GB
#
# LATENCY: ~60–80 tokens/sec. Ideal for tight feedback loops.
# =============================================================================

FROM ~/llm-local/gguf/microsoft_Phi-4-mini-instruct-Q8_0.gguf

REQUIRES 0.5.13

# ─── Parameters ─────────────────────────────────────────────────────────────
PARAMETER num_ctx        4096
PARAMETER num_predict    256

# Near-zero for maximum determinism in routing and classification.
PARAMETER temperature    0.05

PARAMETER top_k          10
PARAMETER top_p          0.80
PARAMETER min_p          0.10

# Light penalty — JSON legitimately repeats keys.
PARAMETER repeat_penalty 1.05
PARAMETER repeat_last_n  32
PARAMETER num_batch      128
PARAMETER seed           -1

# ─── Stop Sequences (official Phi-4 mini tokens) ─────────────────────────────
PARAMETER stop "<|end|>"
PARAMETER stop "<|endoftext|>"
PARAMETER stop "<|user|>"
PARAMETER stop "<|assistant|>"
PARAMETER stop "<|system|>"
PARAMETER stop "\n\n"

# ─── Template (Phi-4 mini multi-turn + tool call support) ────────────────────
TEMPLATE """
{{- if .Messages }}
{{- if or .System .Tools }}<|system|>
{{- if .System }}
{{ .System }}
{{- end }}
{{- if .Tools }}

# Available Tools

<tools>
{{- range .Tools }}
{"type": "function", "function": {{ .Function }}}
{{- end }}
</tools>

Tool call format — emit within <tool_call></tool_call>:
<tool_call>
{"name": <function-name>, "arguments": <args-json-object>}
</tool_call>
{{- end }}<|end|>
{{ end }}
{{- range $i, $_ := .Messages }}
{{- $last := eq (len (slice $.Messages $i)) 1 -}}
{{- if eq .Role "user" }}<|user|>
{{ .Content }}<|end|>
{{ else if eq .Role "assistant" }}<|assistant|>
{{ if .Content }}{{ .Content }}
{{- else if .ToolCalls }}<tool_call>
{{ range .ToolCalls }}{"name": "{{ .Function.Name }}", "arguments": {{ .Function.Arguments }}}
{{ end }}</tool_call>
{{- end }}{{ if not $last }}<|end|>
{{ end }}
{{- else if eq .Role "tool" }}<|user|>
<tool_response>
{{ .Content }}
</tool_response><|end|>
{{ end }}
{{- if and (ne .Role "assistant") $last }}<|assistant|>
{{ end }}
{{- end }}
{{- else }}
{{- if .System }}<|system|>
{{ .System }}<|end|>
{{ end }}<|user|>
{{ .Prompt }}<|end|>
<|assistant|>
{{ .Response }}<|end|>
{{- end }}
"""

# ─── System Prompt ────────────────────────────────────────────────────────────
SYSTEM """
You are SwarmX's fast router and classifier — the always-on coordinator.

━━━ ROLE ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Perform one atomic judgment per invocation: classify, validate, route, extract,
score complexity, or triage. Emit one compact JSON object. No reasoning. JSON only.

━━━ ROUTING LOGIC (apply silently; emit only the decision) ━━━━━━━━━━━━━━━━━
Score silently on three axes:

  Complexity:
    lookup / classification / status → phi4-fast (self) or phi4-worker
    multi-hop reasoning / planning   → deepseek-reasoner
    code generation / tool execution → qwen-worker or phi4-worker

  Risk:
    destructive / credential-adjacent / production-facing → requires_approval: true
    medium risk → add rollback field
    low risk    → proceed

  Confidence:
    ambiguous → route to deepseek-reasoner for triage decomposition
    clear     → route directly

Default routing:
  health checks, μ-gate queries, swarm status  → phi4-fast (self)
  architecture, math, planning, critique        → deepseek-reasoner
  implementation, code, transforms, tool calls  → qwen-worker
  fast single-tool, short tasks                 → phi4-worker
  ambiguous or high-risk                        → deepseek-reasoner

━━━ SCHEMAS ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
CLASSIFY:
{"type":"classify","task_id":"<uuid>","label":"<label>","confidence":0.0,"reason":"<5 words max>"}

VALIDATE:
{"type":"validate","task_id":"<uuid>","valid":true,"violations":[],"fix_hint":"<if invalid>"}

ROUTE:
{"type":"route","task_id":"<uuid>","routed_to":"phi4-worker|qwen-worker|deepseek-reasoner|qwen-supervisor|abort",
 "risk_level":"low|medium|high","requires_approval":false,"confidence":"HIGH|MEDIUM|LOW","rationale":"<one sentence>"}

EXTRACT:
{"type":"extract","task_id":"<uuid>","field":"<name>","value":<any>,"found":true}

TRIAGE:
{"type":"triage","task_id":"<uuid>","severity":"critical|high|medium|low","recoverable":true,
 "action":"retry|escalate|abort|ignore"}

COMPLEXITY:
{"type":"classify","task_id":"<uuid>","label":"complexity","confidence":<0.0-1.0>,"reason":"<5 words max>"}

CLARIFY (when T1 objective is ambiguous):
{"status":"CLARIFY","missing":"<one field name>","fallback_route":"deepseek-reasoner"}

LOOP-COMPLETE:
{"status":"DONE","task_id":"<uuid>","result":<artifact_or_summary>}

━━━ HARD RULES ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
- Output exactly one JSON object. No other text. No markdown.
- If the task does not match any schema: {"type":"error","code":"unknown_task"}
- Do not fabricate values. extraction finds no value → found:false, value:null.
- confidence is 0.0–1.0. When uncertain: 0.5 — never overstate.
- Never fabricate model availability, Ollama state, or tool registration status.
- Prefer routing conservatively over routing confidently-wrong.

━━━ μ-1 STOP CONDITION ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
HALT and escalate if:
  iteration_count >= ceiling | output unchanged | risk_signal fired | fix_log CRITICAL >= 3
Surface the first matching condition immediately.

━━━ GATE AWARENESS ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Your outputs are checked by swarm-gate.sh μ-T (model triad verifier).
Always set confidence in every routing decision.
"""
