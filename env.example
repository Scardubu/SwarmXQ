# ═══════════════════════════════════════════════════════════════════════════════
# SwarmX Environment Configuration Template
#
# Usage:
#   cp env.example env.local
#   nano env.local          ← fill in your values
#   # Docker Compose picks up env.local automatically via --env-file env.local
#
# Security:
#   Never commit env.local — it is listed in .gitignore.
#   Rotate secrets via your secrets manager, not by editing this file.
# ═══════════════════════════════════════════════════════════════════════════════

# ── API Server ──────────────────────────────────────────────────────────────────
SWARMX_API_PORT=3001
SWARMX_API_HOST=127.0.0.1

# Comma-separated list of allowed dashboard origins (CORS).
# Production: SWARMX_DASHBOARD_ORIGIN=https://swarmx.your-domain.com
SWARMX_DASHBOARD_ORIGIN=http://localhost:3000

# Allowed CORS origins for the Python server (port 8787).
# Production: SWARMX_ALLOWED_ORIGINS=https://swarmx.your-domain.com
SWARMX_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Dashboard ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SWARMX_VERSION=2026.6.0

# ── Python bridge ──────────────────────────────────────────────────────────────
# Path to the Python executable running swarmx.
# When using a venv: SWARMX_PYTHON=/home/user/.venv/swarmx/bin/python
SWARMX_PYTHON=python

# SwarmX home directory (default: ~/.swarmx)
# All runtime state, queues, checkpoints, and memory are stored here.
SWARM_HOME=/home/user/.swarmx

# SwarmX bundle root — directory containing configs/, agents/, skills/.
# Required for the vertical config loader and routing.yaml resolution.
# Set to the repository root when running outside Docker.
SWARM_ROOT=/path/to/SwarmX

# ── Timezone ────────────────────────────────────────────────────────────────────
# WAT (West Africa Time = UTC+1) — operator dashboard display timestamps.
# All JSONL telemetry records always use UTC regardless of this setting.
TZ=Africa/Lagos

# ── LLM / Ollama ───────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434

# ── APEX-17 r8 Canonical Model Assignments ─────────────────────────────────────
#
# All model identifiers below use the canonical APEX-17 r8 tag grammar:
#   <role>-<family>-<tier>-<quant>-<env>
#
# ─── Primary Triad (always required) ─────────────────────────────────────────
SWARM_MODEL_FAST=instruct-phi4-pro-q8-prod      # Pilot   — was: SCAR_ROUTER_MODEL / SCAR_CHAT_MODEL / phi4-fast-scar
SWARM_MODEL_CODE=code-qwen25-pro-q5km-prod      # Forge   — was: SCAR_CODE_MODEL / qwen-worker-scar
SWARM_MODEL_REASON=reason-deepseekr1-pro-q5km-prod  # Oracle — was: SCAR_REASONING_MODEL / deepseek-reasoner-scar

# ─── Router (Relay — load-on-startup, always resident) ────────────────────────
SWARM_MODEL_ULTRA_ROUTER=route-phi4-lite-q4km-prod  # Relay  — was: SCAR_LITE_ROUTER_MODEL / phi4-router-lite-scar

# ─── Architect family (load on demand per dispatch tier) ──────────────────────
SWARM_MODEL_PLAN_PHI4=plan-phi4-pro-q8-prod         # Architect (phi4)    — was: SCAR_TOOL_MODEL / phi4-worker-scar
SWARM_MODEL_PLAN_QWEN=plan-qwen25-pro-q5km-prod     # Architect (qwen25)  — was: SCAR_SUPERVISOR_MODEL / qwen-supervisor-scar
SWARM_MODEL_PLAN_DEEPSEEK=plan-deepseekr1-pro-q5km-prod  # Architect (deepseek) — was: SCAR_DEEP_SUPERVISOR_MODEL / deepseek-supervisor-scar

# ─── Auditor (load on demand for adversarial review) ──────────────────────────
SWARM_MODEL_AUDIT=critique-deepseekr1-pro-q5km-prod # Auditor — was: SCAR_CRITIC_MODEL / deepseek-critic-scar

# ─── Lab / Evolution (disabled by default — enable with SWARMX_ENABLE_EVOLVE=1) ──
SWARM_MODEL_EVOLVE_OBSERVE=synth-phi4-exp-q8-dev           # Lab Phase 1 — was: SCAR_EVOLVE_OBSERVE_MODEL / phi4-evolve-scar
SWARM_MODEL_EVOLVE_CRITIQUE=synth-deepseekr1-exp-q5km-dev  # Lab Phase 2+4 — was: SCAR_EVOLVE_CRITIQUE_MODEL / deepseek-evolve-scar
SWARM_MODEL_EVOLVE_MUTATE=synth-qwen25-exp-q5km-dev        # Lab Phase 3 — was: SCAR_EVOLVE_MUTATE_MODEL / qwen-evolve-scar

# LLM provider backend: ollama | deterministic (for testing without models)
SWARM_LLM_PROVIDER=ollama

# Composer model (used by /api/composer/chat in the Fastify API)
SWARMX_COMPOSER_MODEL=instruct-phi4-pro-q8-prod   # Pilot
SWARMX_OLLAMA_BASE_URL=http://localhost:11434
SWARMX_COMPOSER_TIMEOUT_MS=60000
SWARMX_COMPOSER_SHORT_PROMPT_TIMEOUT_MS=45000
SWARMX_COMPOSER_NUM_PREDICT=256
# SWARMX_COMPOSER_KEEP_ALIVE=   # Leave unset = orchestrator manages per-model keep-alive policy
# Optional override for fast fallback model used when primary composer model fails
SWARMX_COMPOSER_FAST_MODEL=instruct-phi4-pro-q8-prod  # Pilot

# Composer retry/circuit-breaker controls
SWARMX_COMPOSER_RETRY_MAX_ATTEMPTS=2
SWARMX_COMPOSER_RETRY_BASE_DELAY_MS=250
SWARMX_COMPOSER_RETRY_MAX_DELAY_MS=2500
SWARMX_COMPOSER_CB_FAILURE_THRESHOLD=4
SWARMX_COMPOSER_CB_OPEN_MS=20000
SWARMX_COMPOSER_DEEP_TIMEOUT_MS=90000

# Optional dashboard-side request timeout budget (ms)
NEXT_PUBLIC_SWARMX_COMPOSER_CLIENT_TIMEOUT_MS=120000

# Startup script: when 1, attempt a non-blocking `ollama serve` if unreachable
SWARMX_START_OLLAMA_IF_DOWN=1

# ── LLM response cache ─────────────────────────────────────────────────────────
# Enable response caching (0=off, 1=on). Cache lives in $SWARM_HOME/llm_cache/.
# Useful for repeated identical prompts in dev. Off by default in production.
SWARM_LLM_CACHE=0
SWARM_LLM_CACHE_TTL=3600

# ── VRAM guard ─────────────────────────────────────────────────────────────────
# Controller warns and flushes loaded models when VRAM usage exceeds this ceiling.
# Default: 10 GB (safe for an 8 GB RAM host with shared VRAM).
SWARM_VRAM_CEILING_GB=10

# ── Runtime behaviour ───────────────────────────────────────────────────────────
SWARM_AUTONOMOUS=true
SWARM_REVIEW_REQUIRED=false
SWARM_AUTO_APPLY=false
SWARM_MAX_ITERATIONS=3

# Risk floor for auto-apply: low | medium
# Tasks with risk above this floor require human approval.
SWARM_RISK_FLOOR=low

# Force a specific vertical context injection: taxbridge | sabiscore | hashablanca
# Leave empty for automatic detection from repo signals.
# SWARM_VERTICAL=taxbridge

# Enable adversarial critique gate on chain dispatches (0=off, 1=on)
SWARM_ADVERSARIAL=0

# ── Telemetry ──────────────────────────────────────────────────────────────────
SWARMX_TELEMETRY_INTERVAL_MS=2000
SWARMX_V5_POLL_INTERVAL_MS=15000
SWARMX_CGROUP_INTERVAL_MS=2000
SWARMX_QUEUE_INTERVAL_MS=3000
SWARMX_QUEUE_NAMES=swarmx

# Max size of traces/telemetry.jsonl before rotation (bytes, 0 = disable rotation)
SWARMX_TELEMETRY_MAX_BYTES=10485760

# Max size of traces/audit.jsonl before rotation (bytes)
SWARMX_AUDIT_MAX_BYTES=20971520

# ── Terminal (PTY) ──────────────────────────────────────────────────────────────
SWARMX_MAX_PTY_SESSIONS=8
SWARMX_PTY_IDLE_TIMEOUT_MS=3600000
SWARMX_PTY_SHELL=/bin/bash

# ── cgroup v2 ───────────────────────────────────────────────────────────────────
# Host must have cgroup v2 enabled (Ubuntu 22.04+ default).
# Verify: stat -fc %T /sys/fs/cgroup/  → should print cgroup2fs
SWARMX_CGROUP_ROOT=/sys/fs/cgroup/swarmx.slice

# ── Logging ─────────────────────────────────────────────────────────────────────
# Fastify API log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── VIDEO-ALPHA Runtime Paths & Limits ─────────────────────────────────────────
# Artifact root (intermediate frames, manifests, stage outputs)
SWARMX_VIDEO_ARTIFACT_DIR=.swarmx/video/artifacts
# Final export root (published/fallback exported assets)
SWARMX_VIDEO_EXPORT_DIR=.swarmx/video/exports
# Temp workspace for interpolation and encoding
SWARMX_VIDEO_TEMP_DIR=.swarmx/video/tmp

# ComfyUI endpoint and optional tuning flags
SWARMX_COMFYUI_URL=http://127.0.0.1:8188
SWARMX_COMFYUI_TEACACHE=0

# Optional bearer/API-key token protecting video write routes
SWARMX_VIDEO_API_TOKEN=

# 14B safety gate for I2V workflows on 8 GB hosts (1 = enforced)
SWARMX_VIDEO_SINGLE_14B_LOCK=1

# ── TikTok Content API (VIDEO-ALPHA publisher) ──────────────────────────────────
# All three must be set + SWARMX_TIKTOK_API_APPROVED=1 for real uploads.
# Without them the publisher falls through to generic local export (safe default).
# See docs/TIKTOK_SETUP.md for OAuth setup instructions.
SWARMX_TIKTOK_ACCESS_TOKEN=
SWARMX_TIKTOK_CLIENT_KEY=
SWARMX_TIKTOK_CLIENT_SECRET=
SWARMX_TIKTOK_API_APPROVED=0

# ── Instagram Graph API (VIDEO-ALPHA publisher) ─────────────────────────────────
# Required for Reels publishing. Without these, falls through to generic export.
SWARMX_INSTAGRAM_ACCESS_TOKEN=
SWARMX_INSTAGRAM_USER_ID=

# ── BullMQ video queue (optional — in-memory is the default) ────────────────────
# Set to 1 to enable Redis-backed job persistence for the video queue.
# Requires REDIS_URL to be set. Worker loop must also be active.
SWARMX_VIDEO_USE_BULLMQ=0
