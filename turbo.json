{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NODE_ENV",
        "NEXT_PUBLIC_SWARMX_VERSION",
        "SWARMX_API_PORT",
        "SWARMX_API_HOST"
      ]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["**/*.ts", "**/*.tsx", "tsconfig.json", "tsconfig*.json"]
    },
    "lint": {
      "inputs": ["**/*.ts", "**/*.tsx", "**/*.mjs", ".eslintrc*", "eslint.config.*"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "**/*.ts",
        "**/*.tsx",
        "**/*.test.ts",
        "**/*.spec.ts",
        "vitest.config.*"
      ],
      "outputs": ["coverage/**"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "NODE_ENV",
        "SWARMX_API_PORT",
        "SWARMX_API_HOST",
        "SWARMX_DASHBOARD_ORIGIN",
        "SWARMX_OLLAMA_BASE_URL",
        "SWARMX_COMPOSER_MODEL",
        "SWARMX_PYTHON",
        "SWARMX_HOME"
      ]
    },
    "clean": {
      "cache": false
    }
  }
}
